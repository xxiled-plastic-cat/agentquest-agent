WORLD_BASE_URL=http://localhost:8787
OPENAI_API_KEY=sk-replace-me
MODEL=gpt-4.1-mini
MAX_STEPS=80

# Wallet auth (required: use seed phrase OR private key)
AGENT_WALLET_SEED_PHRASE="replace with your 25-word Algorand seed phrase"
# AGENT_WALLET_PRIVATE_KEY_BASE64=replace-with-base64-encoded-64-byte-private-key

# Network selection for wallet auth challenge envelope
# localnet | testnet | mainnet | custom
ALGORAND_NETWORK=testnet

# Optional wallet/auth metadata
# AGENT_WALLET_ADDRESS=OPTIONAL_ALGORAND_ADDRESS
# AGENT_PROTOCOL_VERSION=v1
# AGENT_CLIENT_VERSION=1.0.0
# AGENT_BUILD_HASH=git-sha-or-build-id
