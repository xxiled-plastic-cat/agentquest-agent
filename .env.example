# World API (direct world default). For paid Caddy edge, point at the gateway instead.
WORLD_BASE_URL=http://localhost:8787
MAX_STEPS=80

# --- ZeroSignal / zs-proxy (required) ---
# Start zs-proxy locally (default listen 127.0.0.1:8080). Do not use stock OpenAI.
OPENAI_BASE_URL=http://127.0.0.1:8080/v1
# Placeholder for the OpenAI SDK only — zs-proxy ignores it; admission is on-chain wallet seal.
OPEN_AI_API_KEY=zerosignal
# ZeroSignal catalog model id
OPENAI_MODEL=Qwen/Qwen3-Coder-480B-A35B-Instruct
# Responses API reasoning.effort: low | medium | high
OPENAI_REASONING_EFFORT=medium

# Wallet auth (required: use seed phrase OR private key)
# Prefer the SAME 25-word mnemonic later used as the marketplace x402 payer + zs-proxy funder.
AGENT_WALLET_SEED_PHRASE="replace with your 25-word Algorand seed phrase"
# AGENT_WALLET_PRIVATE_KEY_BASE64=replace-with-base64-encoded-64-byte-private-key

# Network selection for wallet auth challenge envelope
# localnet | testnet | mainnet | custom
ALGORAND_NETWORK=testnet

# Payment network defaults (must align with world + facilitator; used when marketplace x402 lands)
PAYMENT_NETWORK=testnet
# Testnet USDC ASA by default
PAYMENT_ASSET_ID=10458941

# Optional wallet/auth metadata
# AGENT_WALLET_ADDRESS=OPTIONAL_ALGORAND_ADDRESS
# AGENT_PROTOCOL_VERSION=v1
# AGENT_CLIENT_VERSION=1.0.0
# AGENT_BUILD_HASH=git-sha-or-build-id
